{
  "name": "brewops",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa"
      },
      "[development]": {
        "auth": {
          "kind": "mocked",
          "users": {
            "emp": {
              "password": "pwd",
              "roles": ["Employee"]
            },
            "inv": {
              "password": "pwd",
              "roles": ["InventoryManager"]
            },
            "mgr": {
              "password": "pwd",
              "roles": ["Manager"]
            }
          }
        }
      },
      "destinations": true,
      "html5-repo": true
    }
  }
}

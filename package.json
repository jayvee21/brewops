{
  "name": "brewops",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "@cap-js/cds-types": "^0.18.0",
    "@types/node": "^24.0.0",
    "tsx": "^4",
    "typescript": "^6.0.0",
    "@cap-js/cds-typer": ">=0.1"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa"
      },
      "[development]": {
        "auth": {
          "kind": "mocked",
          "users": {
            "emp": {
              "password": "pwd",
              "roles": [
                "Employee"
              ]
            },
            "inv": {
              "password": "pwd",
              "roles": [
                "InventoryManager"
              ]
            },
            "mgr": {
              "password": "pwd",
              "roles": [
                "Manager"
              ]
            }
          }
        }
      },
      "destinations": true,
      "html5-repo": true
    }
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  }
}

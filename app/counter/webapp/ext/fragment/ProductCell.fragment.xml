<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <HBox alignItems="Center" id="HBOX">
        <Avatar
            src="{imageUrl}"
            displaySize="S"
            displayShape="Square"
            fallbackIcon="sap-icon://meal"
            class="sapUiTinyMarginEnd" id="img"/>
        <VBox id="vbox">
            <Title text="{name}" level="H6" wrapping="true" id="title"/>
            <Text text="{description}" maxLines="2" id="desc"/>
        </VBox>
    </HBox>
</core:FragmentDefinition>
